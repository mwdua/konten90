# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_MASTER_SPREADSHEET_ID: Central Registry Master Spreadsheet ID for Multi-Tenant registration
VITE_MASTER_SPREADSHEET_ID="1DOZcAkthe_r-zdV-RcS-RYNOVAkyxOiWpw66zp-0duU"

# VITE_GAS_WEBAPP_URL: Set this ONLY for Vercel OPTION A (Google Apps Script Web App Direct Connection).
# It allows seamless serverless reading/writing/uploading to Sheets & Google Drive without Firebase popup domain constraints.
# Example: https://script.google.com/macros/s/AKfycbxxxxxxxxx/exec
VITE_GAS_WEBAPP_URL=""
